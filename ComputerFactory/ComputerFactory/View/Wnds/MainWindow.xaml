<Window x:Class="ComputerFactory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerFactory"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="MainWindow" Height="500" Width="800" Loaded="Window_Loaded" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <RowDefinition Height="50"/>

        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <TextBlock x:Name="NothingFound" Text="Ничего не найдено" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="1" FontSize="20" Visibility="Collapsed"/>
            <StackPanel Margin="20" Grid.Column="0" >
                <TextBox x:Name="SearchClient" Height="30" Width="400" VerticalAlignment="Top" Margin="0 0 0 0" ></TextBox>
                <Button Style="{StaticResource Btns}" Content="Найти"  HorizontalAlignment="Right" Margin="0 -30 15 0" Click="BtnSearch_Click"></Button>
                <Button Style="{StaticResource Btns}" Content="Весь список"  HorizontalAlignment="Left" Margin="0 -30 15 0" Click="BtnAllClients_Click"></Button>
                
                <ListView x:Name="ClientList" HorizontalAlignment="Center" VerticalAlignment="Center" Height="195" Width="520" Margin="20" SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID" DisplayMemberBinding="{Binding client_id}" Width="50"/>
                            <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding name}" Width="160"/>
                            <GridViewColumn Header="Улица" DisplayMemberBinding="{Binding street}" Width="200"/>
                            <GridViewColumn Header="Дом" DisplayMemberBinding="{Binding houseNumber}" Width="75"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Grid>
       
        <Grid Grid.Row="1" >
            <StackPanel VerticalAlignment="top" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource Btns}"   Content="Добавить" Click="BtnAddClient_Click"/>
                <Button Style="{StaticResource Btns}"  Margin="50 0 0 0" Content="Удалить" Click="BtnDeleteClient_Click"/>
                <Button Style="{StaticResource Btns}" Margin="50 0 0 0 " Content="Обновить" Click="BtnUpdateClient_Click"/>
            </StackPanel>
        </Grid>

        

    </Grid>
</Window>
