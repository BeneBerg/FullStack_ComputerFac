<Window x:Class="ComputerFactory.View.Wnds.UpdateClientWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerFactory.View.Wnds"
        mc:Ignorable="d"
           Title="AddClientWnd" Height="300" Width="350">
    <Grid>
        <StackPanel HorizontalAlignment="Center" Margin="10">
            <TextBlock Text="Наименование"/>
            <TextBlock x:Name="companyName" Width="200" Margin="0 0 0 10 "/>
            <TextBlock Text="Улица"/>
            <TextBox x:Name="streetText" Width="200" Margin="0 0 0 10"/>
            <TextBlock Text="Дом"/>
            <TextBox x:Name="houseNum" Width="200" Margin="0 0 0 10"/>

            <Button Style="{StaticResource Btns}" Content="Обновить данные" Margin="0 20 0 0 " Click="UpdateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
